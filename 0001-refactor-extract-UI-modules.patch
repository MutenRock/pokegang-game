+  slots_win:         'music/ME/SlotsWin.mp3',
+  slots_big:         'music/ME/SlotsBigWin.mp3',
+};
+
+const JinglePlayer = (() => {
+  let _current = null;
+  function _enabled() { return getAudioState()?.settings?.musicEnabled === true; }
+
+  return {
+    play(key) {
+      if (!_enabled()) return;
+      const src = JINGLES[key];
