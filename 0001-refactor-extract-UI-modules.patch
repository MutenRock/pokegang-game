+/**
+ * SE (Sound Effects) — sons d'attaque et événements gameplay.
+ * Utilise Audio HTML plutôt que Web Audio pour les fichiers complexes.
+ */
+const SE_SOUNDS = {
+  buy:        'music/SE/Charm.mp3',
+  level_up:   'music/SE/BW2Summary.mp3',
+  slash:      'music/SE/Slash.mp3',
