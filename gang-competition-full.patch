+
+// ── Panneau liste des gangs ───────────────────────────────────────
+async function _renderGangListPanel(el) {
+  if (!el) return;
+  el.innerHTML = `
+    <div style="background:var(--bg-panel);border:1px solid var(--border);border-radius:var(--radius);padding:14px">
